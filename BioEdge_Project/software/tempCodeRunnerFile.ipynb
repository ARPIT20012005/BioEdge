import pandas as pd
import numpy as np
import torch
import torch.nn as nn
import torch.optim as optim
import os
import gzip
import zipfile
import xml.etree.ElementTree as ET

print("--- BIOEDGE PHASE 1: INITIALIZING ---")

# =====================================================================
# STEP 1: LOAD THE BIOLOGICAL DATA
# =====================================================================
excel_file = '../data/41586_2018_461_MOESM3_ESM.xlsx'
fasta_file = '../data/GRCh37.p13_chr17.fna.gz'

def resolve_file_path(file_name):
    # 1) direct path
    if os.path.exists(file_name):
        return file_name

    # 2) in current working directory
    cwd_candidate = os.path.join(os.getcwd(), file_name)
    if os.path.exists(cwd_candidate):
        return cwd_candidate

    # 3) recursive search from current working directory by basename
    target = os.path.basename(file_name)
    for root, _, files in os.walk(os.getcwd()):
        if target in files:
            return os.path.join(root, target)

    # 4) fallback: pick a likely file by extension
    ext = os.path.splitext(target)[1].lower()
    if ext in {".csv", ".fna", ".gz", ".xlsx"}:
        for root, _, files in os.walk(os.getcwd()):
            for f_name in files:
                if f_name.lower().endswith(ext):
                    return os.path.join(root, f_name)

    raise FileNotFoundError(f"Could not locate file: {file_name}\nCurrent working directory: {os.getcwd()}")

def load_mutations_from_xlsx(xlsx_path):
    with zipfile.ZipFile(xlsx_path) as z:
        shared_strings = []
        if 'xl/sharedStrings.xml' in z.namelist():
            sst_root = ET.fromstring(z.read('xl/sharedStrings.xml'))
            for si in sst_root.iter():
                if si.tag.endswith('si'):
                    texts = []
                    for node in si.iter():
                        if node.tag.endswith('t') and node.text is not None:
                            texts.append(node.text)
                    shared_strings.append(''.join(texts))

        sheet_name = 'xl/worksheets/sheet1.xml'
        if sheet_name not in z.namelist():
            sheet_candidates = [n for n in z.namelist() if n.startswith('xl/worksheets/sheet') and n.endswith('.xml')]
            if not sheet_candidates:
                raise ValueError("No worksheet XML found in workbook")
            sheet_name = sheet_candidates[0]

        sheet_root = ET.fromstring(z.read(sheet_name))
        sheet_data = None
        for elem in sheet_root.iter():
            if elem.tag.endswith('sheetData'):
                sheet_data = elem
                break
        if sheet_data is None:
            raise ValueError("No sheetData found in worksheet XML")

        rows = []
        for row in sheet_data:
            if not row.tag.endswith('row'):
                continue
            row_cells = {}
            for c in row:
                if not c.tag.endswith('c'):
                    continue
                ref = c.attrib.get('r')
                if not ref:
                    continue
                col_letters = ''.join(ch for ch in ref if ch.isalpha())
                col_idx = 0
                for ch in col_letters:
                    col_idx = col_idx * 26 + (ord(ch.upper()) - ord('A') + 1)
                col_idx -= 1
                cell_type = c.attrib.get('t')
                v_elem = None
                for child in c:
                    if child.tag.endswith('v'):
                        v_elem = child
                        break
                if v_elem is None or v_elem.text is None:
                    value = None
                else:
                    raw = v_elem.text
                    if cell_type == 's':
                        try:
                            idx = int(raw)
                            value = shared_strings[idx] if 0 <= idx < len(shared_strings) else None
                        except Exception:
                            value = None
                    else:
                        value = raw
                row_cells[col_idx] = value
            rows.append(row_cells)

        if not rows:
            raise ValueError("No rows found in worksheet")

        header_row = rows[0]
        header_by_name = {}
        for idx, val in header_row.items():
            if val:
                header_by_name[val] = idx

        required_cols = ['position (hg19)', 'reference', 'alt', 'func.class']
        missing = [c for c in required_cols if c not in header_by_name]
        if missing:
            raise ValueError(f"Required columns not found in Excel header: {missing}")

        data = {c: [] for c in required_cols}
        for row_cells in rows[1:]:
            row_values = {}
            skip = False
            for col in required_cols:
                idx = header_by_name[col]
                val = row_cells.get(idx)
                if val is None or val == '':
                    skip = True
                    break
                row_values[col] = val
            if skip:
                continue
            try:
                pos_val = int(float(row_values['position (hg19)']))
            except ValueError:
                continue
            data['position (hg19)'].append(pos_val)
            data['reference'].append(str(row_values['reference']))
            data['alt'].append(str(row_values['alt']))
            data['func.class'].append(str(row_values['func.class']))

        return pd.DataFrame(data)

excel_path = resolve_file_path(excel_file)
fasta_path = resolve_file_path(fasta_file)

print(f"Loading Answer Key: {excel_path}...")
mutations = load_mutations_from_xlsx(excel_path)

print(f"Loading Chromosome 17 Dictionary: {fasta_path}...")
if fasta_path.endswith('.gz'):
    with gzip.open(fasta_path, 'rt') as f:
        lines = f.readlines()
else:
    with open(fasta_path, 'r') as f:
        lines = f.readlines()
# Skip the > header line and merge all DNA letters into one massive string
chr17_seq = ''.join([line.strip() for line in lines[1:]])
print(f"Chromosome 17 loaded: {len(chr17_seq):,} total letters.")

# =====================================================================
# STEP 2: CREATE THE DIGITAL FLASHCARDS
# =====================================================================
print("\nBuilding Training Data (Sliding Window & Binary Encoding)...")

# 1 = Pathogenic (Cancerous), 0 = Benign (Safe)
mutations['label'] = mutations['func.class'].apply(lambda x: 1 if x == 'LOF' else 0)

WINDOW_SIZE = 30 # 30 letters before, 30 letters after

def process_dna_window(row, ref_seq):
    # Genomic positions are 1-based, Python strings are 0-based
    pos = int(row['position (hg19)']) - 1 
    
    # Slice the surrounding healthy DNA 
    context_before = ref_seq[pos - WINDOW_SIZE : pos]
    context_after  = ref_seq[pos + 1 : pos + 1 + WINDOW_SIZE]
    
    # Sandwich the mutated 'alt' letter in the middle (Total: 61 letters)
    mutated_seq = context_before + row['alt'] + context_after
    
    # Convert English letters to 2-bit hardware logic (A=00, C=01, T=10, G=11)
    mapping = {'A': [0,0], 'C': [0,1], 'T': [1,0], 'G': [1,1]}
    encoded_array = []
    for base in mutated_seq:
        encoded_array.extend(mapping.get(base.upper(), [0,0]))
        
    return np.array(encoded_array, dtype=np.float32)

mutations['binary_input'] = mutations.apply(lambda row: process_dna_window(row, chr17_seq), axis=1)

# =====================================================================
# STEP 3: BUILD THE PYTORCH MICRO-AI (THE BRAIN)
# =====================================================================
print("\nInitializing 1D-CNN Micro-AI Architecture...")

X = np.stack(mutations['binary_input'].values)
y = mutations['label'].values

# Shape the data for the Convolutional Neural Network
X_tensor = torch.tensor(X, dtype=torch.float32).unsqueeze(1) 
y_tensor = torch.tensor(y, dtype=torch.float32).unsqueeze(1)

class BioEdge_Brain(nn.Module):
    def __init__(self):
        super(BioEdge_Brain, self).__init__()
        # The Stencil: 4 filters, looking at 5 bits of DNA at a time
        self.conv1 = nn.Conv1d(in_channels=1, out_channels=4, kernel_size=5, stride=1)
        self.relu = nn.ReLU()
        # The Final Decision layer (122 bits - 5 + 1 = 118. 118 * 4 filters = 472)
        self.fc1 = nn.Linear(4 * 118, 1)
        self.sigmoid = nn.Sigmoid()

    def forward(self, x):
        x = self.conv1(x)
        x = self.relu(x)
        x = x.view(x.size(0), -1) 
        x = self.fc1(x)
        x = self.sigmoid(x)
        return x

model = BioEdge_Brain()

# =====================================================================
# STEP 4: TRAIN THE AI (LEARNING THE MATHEMATICAL SHAPE OF CANCER)
# =====================================================================
print("\n--- Starting AI Training (50 Epochs) ---")
criterion = nn.BCELoss()
optimizer = optim.Adam(model.parameters(), lr=0.01)

epochs = 50
for epoch in range(epochs):
    optimizer.zero_grad()           
    predictions = model(X_tensor)   
    loss = criterion(predictions, y_tensor) 
    loss.backward()                 
    optimizer.step()                
    
    if (epoch + 1) % 10 == 0:
        predicted_classes = (predictions > 0.5).float()
        accuracy = (predicted_classes == y_tensor).sum() / float(y_tensor.shape[0])
        print(f"Epoch {epoch+1}/{epochs} | Loss: {loss.item():.4f} | Accuracy: {accuracy.item()*100:.2f}%")

# =====================================================================
# STEP 5: THE HARDWARE BRIDGE (QUANTIZATION & EXPORT)
# =====================================================================
print("\n--- Translating Brain to Hardware ---")


# Extract the floating-point decimals from the trained AI
float_weights = model.conv1.weight.data.numpy()

# Multiply by 127 and round to convert them into 8-bit integers for the FPGA
SCALE_FACTOR = 127.0 
int_weights = np.round(float_weights * SCALE_FACTOR).astype(int)

# Write these integers to a text file that Xilinx Vivado can read
mem_file = 'weights_export.mem'
with open(mem_file, 'w') as f:
    for filter_weights in int_weights:
        for weight in filter_weights[0]:
            f.write(f"{weight}\n")

print(f"SUCCESS! {mem_file} generated.")
print("Original Decimal (Filter 1, Weight 1):", float_weights[0][0][0])
print("Quantized Integer (Filter 1, Weight 1):", int_weights[0][0][0])
print("\n--- PHASE 1 COMPLETE ---")